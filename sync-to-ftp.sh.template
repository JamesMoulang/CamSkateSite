#!/bin/bash

# FTP Sync Script for Cam Skate Website
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to sync-to-ftp.sh
# 2. Replace YOUR_FTP_USERNAME and YOUR_FTP_PASSWORD with actual credentials
# 3. Make it executable: chmod +x sync-to-ftp.sh
# 4. Requires lftp to be installed:
#    - macOS: brew install lftp
#    - Ubuntu/Debian: sudo apt install lftp

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

echo "Starting FTP sync..."

lftp -u "YOUR_FTP_USERNAME,YOUR_FTP_PASSWORD" ftp.cam-skate.co.uk <<EOF
set ssl:verify-certificate no
mirror -R --delete --exclude .git/ --exclude .DS_Store --exclude node_modules/ --exclude sync-to-ftp.sh --exclude sync-to-ftp.sh.template --exclude readme.md --exclude .gitignore --exclude CLAUDE.md . .
quit
EOF

echo "Sync complete!"
